	-$(DEL_FILE) ../$(TARGET)
	-$(MOVE) $(TARGET) ../$(TARGET)
	-$(DEL_FILE) ../$(TARGET0)
	-$(DEL_FILE) ../$(TARGET1)
	-$(DEL_FILE) ../$(TARGET2)
